@page "/apiresources/{ApiResourceId:int}/history"
@inherits UserRoleBasePage
@using IdentityServer.Abstraction.DTO.ApiResources
@using IdentityServer.Abstraction.DTO.History
@using IdentityServer.AdminPortal.Web.Components.History

@inject IAdminApiService AdminApi
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<div class="container-fluid">

    <ErrorAlert @bind-ErrorMessage="@errorMessage" />

    @if (isLoading)
    {
        <p><em>Loading history...</em></p>
    }
    else if (historyData != null)
    {
        <NavigationHeader Address="@PageRoutes.ApiResourcesEdit(ApiResourceId)" Title="Back to API Resource" />

        <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
            <h3 class="me-auto text-break">History for '@historyData.EntityName'</h3>
        </div>

        <div class="alert alert-info mb-3">
            <strong>Note:</strong> This page shows all historical changes to the API resource and its nested entities (secrets, scopes, roles, role mappings, etc.).
        </div>

        @if (historyData.History == null || !historyData.History.Any())
        {
            <div class="alert alert-warning">
                No history records found for this API resource.
            </div>
        }
        else
        {
            <HistoryTimeline HistoryEntries="historyData.History" 
                             InitialEntityTypeFilter="@EntityType" 
                             ParentEntityId="@ApiResourceId"
                             CurrentApiResource="@currentApiResource"
                             OnRefreshRequired="@LoadData" />
        }

        <NavigationFooter Address="@PageRoutes.ApiResourcesEdit(ApiResourceId)" Title="Back to API Resource" />
    }
</div>

@code {
    [Parameter]
    public int ApiResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? EntityType { get; set; }

    private HistoryResponseDto? historyData;
    private ApiResourceDtoRead? currentApiResource;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (!isLoading)
        {
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        if (ApiResourceId == 0)
        {
            errorMessage = "Invalid API resource ID.";
            isLoading = false;
            return;
        }

        try
        {
            // Load history and current API resource data in parallel
            var historyTask = AdminApi.GetApiResourceHistory(ApiResourceId);
            var apiResourceTask = AdminApi.GetApiResource(ApiResourceId);

            await Task.WhenAll(historyTask, apiResourceTask);

            var historyResult = await historyTask;
            var apiResourceResult = await apiResourceTask;

            if (historyResult.IsSuccess)
            {
                historyData = historyResult.Result;
            }
            else
            {
                errorMessage = historyResult.ErrorMessage;
            }

            if (apiResourceResult.IsSuccess)
            {
                currentApiResource = apiResourceResult.Result;
            }
            // Don't fail if API resource load fails, undo will just be disabled
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load history: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
