@page "/apiresources/edit/{ApiResourceId:int}/import/roles"

@inherits UserRoleBasePage

@inject IAdminApiService AdminApi
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<div class="container">
    <ErrorAlert @bind-ErrorMessage="@errorMessage" />

    @if (ApiResource == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <NavigationHeader Address="@PageRoutes.ApiResourcesEdit(ApiResourceId)" Title="Back to the API Resource" />

        <div class="mb-3">
            <h3 class="me-auto text-break">Import Role Mappings for API Resource '@ApiResource.DisplayName'</h3>
        </div>

        @if (ShouldShowExportHint())
        {
            <div class="row justify-content-between my-3 alert alert-info">
                <div class="col-auto my-auto">
                    <strong>Pro tip!</strong> Export existing role mappings as a backup
                </div>
                <div class="col text-end">
                    <ApiResourceRoleExport ApiResource="@ApiResource" Class="me-2"
                                           UserObjectId="@UserObjectId"
                                           UserName="@UserName"
                                           OnExportCompleted="CloseExportHint"
                                           SilentlyExportAllRoles="true" />
                    <TelerikButton Size="small" OnClick="CloseExportHint" ButtonType="ButtonType.Button" FillMode="link" Icon="@SvgIcon.X" />
                </div>
            </div>
        }

        <RoleImportWizard @ref="_importWizard"
                          TRoleMapping="ApiResourceRoleMappingValueObject"
                          TDtoImport="ApiResourceRoleImportDto"
                          TImportModel="ApiResourceRoleImportModel"
                          ClientSideDataValidator="RoleImportDtoValidationService<ApiResourceRoleMappingValueObject>.IsValid"
                          ServerSideDataValidator="@ValidateImportApiResourceRoles"
                          OnImportCompleted="@ReturnToApiResourceEditPage"
                          PerformImportFunc="@ImportApiResourceRoles"
                          RoleImportComparer="@_apiResourceRoleComparer" />

        <NavigationFooter Address="@PageRoutes.ApiResourcesEdit(ApiResourceId)" Title="Back to the API Resource" />
    }

</div>

@code {
    [Parameter]
    public int ApiResourceId { get; set; }

    private ApiResourceDtoRead ApiResource = default!;
    private string? errorMessage;

    private RoleImportWizard<ApiResourceRoleMappingValueObject, ApiResourceRoleImportDto, ApiResourceRoleImportModel> _importWizard { get; set; } = default!;
    private RoleImportComparer<ApiResourceRoleMappingValueObject> _apiResourceRoleComparer = default!;

    private bool _showExportHint = true;

    private async Task<OperationStatus> ImportApiResourceRoles(ApiResourceRoleImportDto importDto)
    {
        var callResult = await AdminApi.ImportApiResourceRoles(ApiResource, importDto);

        if (callResult.IsSuccess)
        {
            return callResult.Result;
        }
        else
        {
            return new OperationStatus { Errors = { callResult.ErrorMessage ?? "Unknown error" } };
        }
    }

    private void ReturnToApiResourceEditPage()
    {
        NavigationManager.NavigateTo(PageRoutes.ApiResourcesEdit(ApiResourceId));
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (ApiResource != null)
        {
            return;
        }

        if (ApiResourceId == 0)
        {
            errorMessage = "The specified entity was not found.";
            return;
        }

        var callResult = await AdminApi.GetApiResource(ApiResourceId);
        if (callResult.IsSuccess)
        {
            errorMessage = null;
            ApiResource = callResult.Result;
            base.UpdatePageAccessBasedOnRoleReturnedByApi(ApiResource.AccessLevel);
            _apiResourceRoleComparer = new RoleImportComparer<ApiResourceRoleMappingValueObject>(
                ApiResource.Roles,
                rm => new ApiResourceRoleMappingValueObject { MappingType = rm.MappingType.ToString(), Value = rm.Value, Description = rm.Description });
        }
        else
        {
            errorMessage = callResult.ErrorMessage;
        }
    }

    internal async Task ValidateImportApiResourceRoles(ApiResourceRoleImportModel importModel)
    {
        var callResult = await AdminApi.ValidateImportApiResourceRoles(ApiResource, importModel.FileParsingStatus.Result);

        if (callResult.IsSuccess)
        {
            importModel.FileDataValidationStatus = callResult.Result;
        }
        else
        {
            importModel.FileDataValidationStatus.Errors.Add(callResult.ErrorMessage ?? "Unknown error");
            var errors = GetFlatErrors(callResult);
            if (errors?.Count > 0)
            {
                importModel.FileDataValidationStatus.Errors.AddRange(errors);
            }
        }
    }

    private static List<string>? GetFlatErrors<T>(ApiCallResult<T> callResult)
    {
        if (callResult.Details == null)
        {
            return null;
        }

        var flatErrors = callResult.GetFlatErrors();
        if (flatErrors?.Count > 0)
        {
            return flatErrors;
        }
        
        // Fallback: serialize the dictionary as-is
        return callResult.Details.Select(kvp => $"{kvp.Key}: {kvp.Value}").ToList();
    }

    private bool ShouldShowExportHint()
    {
        return _showExportHint && _importWizard?.IsCompleted() == false;
    }

    private void CloseExportHint()
    {
        _showExportHint = false;
    }
}
