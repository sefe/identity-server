{
    "IdentityServer": {
        "Authority": "https://localhost:5200/",
        //"Authority": "https://identityserverdv:5200/",
        "ClientId": "identityserver.admin",
        "ResponseType": "code",
        "DefaultScopes": [
            "identityserver.admin"
        ],
        "CachingOptions": {
            "Enabled": false
        }
    },
    "Features": {
        "FilterUserRoleOnLogin": false,
        "MaxVisibleResourceWriters": 3
    },
    "Theme": {
        "BackgroundColor": "#6F9B4A" //earthy green (prod)
    },
    "System": {
        "Environment": "IDP DV 01",
        "EnvironmentTier": "DV",
        "SecurityNotice": "SEFE Marketing & Trading Security Notice",
        "SecurityDisclaimerText": "Only authorized users can login onto this system, all other access will be considered unauthorized and is not permitted. By logging onto this system you agree to comply with the Acceptable Use of Information Processing Facilities and all other policies governing use of SEFE Marketing & Trading information processing facilities.",
        "SupportEmailAddress": "IdentityServerSupport@sefe.eu"
    },
    "SecretExpiration": {
        "MaxValidityYears": 3,
        "DaysBeforeExpirationNotification": 60
    }
}
