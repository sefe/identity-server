@inherits EditableComponentBase

@inject IAdminApiService AdminApi
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IConfirmationService ConfirmationService

<div class="row justify-content-between my-3">
    <div class="col-auto my-auto">
        <h5 class="my-0">Role Mappings</h5>
    </div>
    <div class="col text-end">
        @if (Application.Roles.Count > 0)
        {
            <ClientRoleExport Client="@Application" UserObjectId="@UserObjectId" UserName="@UserName" Class="me-2" />
        }
        @if (!IsReadonly)
        {
            <TelerikButton Size="small" OnClick="NavigateToRoleImportPage"
                           ButtonType="ButtonType.Button" FillMode="link" Icon="@SvgIcon.HyperlinkOpen">Import</TelerikButton>
        }
    </div>
</div>

<ErrorAlert @bind-ErrorMessage="@errorMessage" />

<ClientRoleList Client="Application" IsReadonly="IsReadonly" OnClientUpdate="NotifyRolesUpdatedAsync" />

<ClientRoleMapListItem IsReadonly="IsReadonly || Application.Roles.Count == 0" OnCreateNew="() => CreateMapping(ClientRoleMapType.SecurityGroup)"
                       MapType="RoleMapType.SecurityGroup" MappedRoles="GetMappedRoles(ClientRoleMapType.SecurityGroup)" OnDeleteRoleMapping="DeleteRoleMapping" />
<ClientRoleMapListItem IsReadonly="IsReadonly || Application.Roles.Count == 0" OnCreateNew="() => CreateMapping(ClientRoleMapType.UserObjectId)"
                       MapType="RoleMapType.UserObjectId" MappedRoles="GetMappedRoles(ClientRoleMapType.UserObjectId)" OnDeleteRoleMapping="DeleteRoleMapping" />

<ClientRoleMapPicker @ref=RoleMapPicker ExistingRoles="Application.Roles" OnRoleMappingConfirmed="HandleRoleMappingDetailsResult" />

@code {
    [Parameter]
    public ClientDtoRead Application { get; set; } = default!;

    [Parameter]
    public string UserObjectId { get; set; } = string.Empty;
    [Parameter]
    public string UserName { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnApplicationUpdate { get; set; }

    private string? errorMessage;

    private ClientRoleMapPicker RoleMapPicker = default!;

    private Task NotifyRolesUpdatedAsync() => OnApplicationUpdate.InvokeAsync("Roles");

    private Task NotifyRoleMappingsUpdatedAsync() => OnApplicationUpdate.InvokeAsync("Role Mappings");

    private async Task HandleRoleMappingDetailsResult(ClientPropertyRoleMappingDtoCreate newRoleMapping)
    {
        if (IsReadonly)
        {
            return;
        }
        if (Application == null)
        {
            return;
        }

        var callResult = await AdminApi.AddClientRoleMapping(newRoleMapping);
        if (callResult.IsSuccess)
        {
            errorMessage = null;
            var role = Application.Roles.Find(r => r.Id == newRoleMapping.ClientRoleId);
            if (role != null)
            {
                role.Mappings ??= new List<ClientPropertyRoleMappingDtoRead>();
                role.Mappings.Add(callResult.Result);
                await NotifyRoleMappingsUpdatedAsync();
            }
            else
            {
                errorMessage = "The specified role was not found.";

            }
            NotificationService.ShowInfo($"Role Mapping for '{callResult.Result.Description}' created.");
        }
        else
        {
            errorMessage = callResult.ErrorMessage;
        }
    }

    private IEnumerable<ClientMappedRole> GetMappedRoles(ClientRoleMapType mapType)
    {
        return Application.Roles.SelectMany(role => role.Mappings, (role, mapping) => new ClientMappedRole
        {
            ClientRoleId = role.ClientId,
            ClientRoleName = role.RoleName,
            RoleMapping = mapping
        }).Where(r => r.RoleMapping.MappingType == mapType);
    }

    private async Task DeleteRoleMapping(ClientPropertyRoleMappingDtoRead roleMapping)
    {
        if (IsReadonly)
        {
            return;
        }

        var confirmed = await ConfirmationService.ConfirmAsync("Delete Confirmation",
            "Are you sure you want to delete this role mapping?");

        if (!confirmed)
        {
            return;
        }

        var callResult = await AdminApi.DeleteClientRoleMapping(roleMapping);
        if (callResult.IsSuccess)
        {
            errorMessage = null;
            Application.Roles.Find(r => r.Id == roleMapping.ClientRoleId)!.Mappings!.Remove(roleMapping);
            NotificationService.ShowInfo($"Role Mapping for '{roleMapping.Description}' deleted.");
            await NotifyRoleMappingsUpdatedAsync();
        }
        else
        {
            errorMessage = callResult.ErrorMessage;
        }
    }

    private void CreateMapping(ClientRoleMapType roleMapType)
    {
        if (IsReadonly)
        {
            return;
        }

        if (Application.Roles == null || Application.Roles.Count == 0)
        {
            return;
        }

        var roleMapping = new ClientPropertyRoleMappingDtoCreate() { ClientId = Application.Id, MappingType = roleMapType };

        OpenRoleMappingPicker(roleMapping);
    }

    private void OpenRoleMappingPicker(ClientPropertyRoleMappingDtoCreate roleMapping)
    {
        if (IsReadonly)
        {
            return;
        }

        RoleMapPicker.OpenRoleMappingPicker(roleMapping);
    }

    private void NavigateToRoleImportPage()
    {
        NavigationManager.NavigateTo(PageRoutes.ApplicationsImportRoles(Application.Id));
    }
}
