@inherits EditableComponentBase

@inject IAdminApiService AdminApi
@inject IConfirmationService ConfirmationService

<div class="card mb-3">
    <div class="card-body">

        <div class="row justify-content-between mb-3">
            <div class="col-auto">
                <span class="h3 text-break">Cloning Application '@existingResourceDisplayName'</span>
                <span class="text-muted ms-3 text-break">(ID: @existingResourceIdentifier)</span>
            </div>
        </div>

        <div class="alert alert-warning mb-3">
            The following properties <strong>won't be copied</strong>.
            <ul>
                <li>Secrets</li>
                <li>API Scopes</li>
                <li>CORS Origins</li>
                <li>EntraID Apps</li>
                <li>Redirect URIs (except <i>localhost</i>)</li>
                <li>Post-Logout Redirect URIs (except <i>localhost</i>)</li>
            </ul>
        </div>

        <TelerikForm Model="@ApplicationCopy" OnValidSubmit="@HandleValidSubmit" ButtonsLayout="FormButtonsLayout.Center">
            <FormValidation>
                <DataAnnotationsValidator />
            </FormValidation>
            <FormItems>
                <FormGroup Columns="@FormGroupColumns" ColumnSpacing="@FormGroupColumnSpacing">
                    <FormItem>
                        <Template>
                            <RequiredFieldLabel ForTarget="clientId" LabelText="Identifier" />
                            <TelerikTextBox id="clientId" ariadescribedby="clientIdHelpBlock" @bind-Value="ApplicationCopy.ClientId" />
                            <div id="clientIdHelpBlock" class="k-form-hint">@Constants.Limits.Client.Name.PatternInfo</div>
                            <TelerikValidationMessage For="@(() => ApplicationCopy.ClientId)" />
                            @if (!string.IsNullOrEmpty(validationMessageForId))
                            {
                                <span class="k-form-error k-invalid-msg" id="customValidationError" role="alert">@validationMessageForId</span>
                            }
                        </Template>
                    </FormItem>
                    <FormItem>
                        <Template>
                            <RequiredFieldLabel ForTarget="clientDisplayName" LabelText="Display Name" />
                            <TelerikTextBox id="clientDisplayName" ariadescribedby="clientDisplayNameHelpBlock" @bind-Value="ApplicationCopy.ClientName" />
                            <div id="clientDisplayNameHelpBlock" class="k-form-hint">Human-readable name. Keep it short and clear.</div>
                            <TelerikValidationMessage For="@(() => ApplicationCopy.ClientName)" />
                        </Template>
                    </FormItem>
                    <FormItem>
                        <Template>
                            <RequiredFieldLabel ForTarget="clientSystemPermission" LabelText="System Permission" />
                            <SystemPermissionEnvironmentPicker Id="clientSystemPermission"
                                                               @bind-Value="@ApplicationCopy.SystemPermissionEnvironmentId"
                                                               OnError="@(msg => errorMessage = msg)" />
                            <TelerikValidationMessage For="@(() => ApplicationCopy.SystemPermissionEnvironmentId)" />
                        </Template>
                    </FormItem>
                </FormGroup>
            </FormItems>
            <FormButtons>
                <TelerikButton ButtonType="ButtonType.Button" ThemeColor="secondary" OnClick="CheckDirtyAndCancel">Cancel</TelerikButton>
                <TelerikButton ButtonType="ButtonType.Submit" ThemeColor="primary">Create</TelerikButton>
            </FormButtons>
        </TelerikForm>

        <TelerikMediaQuery Media="@LargeScreenMediaQuery" OnChange="@((bool matches) => { IsLargeScreen = matches; ConfigureFormLayout(); })" />

        <ErrorAlert @bind-ErrorMessage="@errorMessage" CssClass="mt-2" />

        <TelerikLoaderContainer Visible="@awaitingResults" />
    </div>
</div>

@code {
    [Parameter]
    public int ApplicationId { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public EventCallback<ClientDtoRead> OnSave { get; set; }

    private string? validationMessageForId;

    private string? existingResourceIdentifier;
    private string? existingResourceDisplayName;

    private readonly ClientDtoClone ApplicationCopy = new()
        {
            ClientId = string.Empty,
            ClientName = string.Empty,
        };
    private string? errorMessage;
    protected bool awaitingResults = true;

    private int FormGroupColumns { get; set; } = 1;
    private string FormGroupColumnSpacing { get; set; } = string.Empty;
    private string LargeScreenMediaQuery { get; set; } = "(min-width: 992px)"; // matches Bootstrap lg qualifier
    private bool IsLargeScreen { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        ApplicationCopy.Id = ApplicationId;

        awaitingResults = true;
        var callResult = await AdminApi.GetClient(ApplicationId);
        if (callResult.IsSuccess)
        {
            existingResourceIdentifier = callResult.Result.ClientId ?? string.Empty;
            existingResourceDisplayName = callResult.Result.ClientName ?? string.Empty;

            ApplicationCopy.ClientId = existingResourceIdentifier;
            ApplicationCopy.ClientName = existingResourceDisplayName;

            ValidateCustomRules();
        }
        else
        {
            errorMessage = callResult.ErrorMessage;
        }
        awaitingResults = false;
    }

    private async Task HandleValidSubmit()
    {
        var hasErrors = ValidateCustomRules();
        if (!hasErrors)
        {
            await DoClone(ApplicationCopy);
        }
    }

    private bool ValidateCustomRules()
    {
        validationMessageForId = null;

        var hasErrors = false;

        if (string.Equals(existingResourceIdentifier, ApplicationCopy.ClientId))
        {
            validationMessageForId = "Please provide a new unique identifier.";
            hasErrors = true;
        }

        return hasErrors;
    }

    private async Task DoClone(ClientDtoClone cloningRequest)
    {
        awaitingResults = true;
        var callResult = await AdminApi.CloneClient(cloningRequest);
        if (callResult.IsSuccess)
        {
            errorMessage = null;
            await OnSave.InvokeAsync(callResult.Result);
        }
        else
        {
            errorMessage = callResult.ErrorMessage;
        }
        awaitingResults = false;
    }

    private async Task CheckDirtyAndCancel()
    {
        if (IsMeaningful(ApplicationCopy.ClientId, existingResourceIdentifier) || IsMeaningful(ApplicationCopy.ClientName, existingResourceDisplayName))
        {
            var confirmed = await ConfirmationService.ConfirmLeavingDirtyPageAsync();
            if (!confirmed)
            {
                return;
            }
        }
        await OnCancel.InvokeAsync();
    }

    private static bool IsMeaningful(string? value, string? defaultValue)
    {
        return !string.IsNullOrEmpty(value) && value != defaultValue;
    }

    private void ConfigureFormLayout()
    {
        if (IsLargeScreen)
        {
            FormGroupColumns = 3;
            FormGroupColumnSpacing = "2em";
        }
        else
        {
            FormGroupColumns = 1;
            FormGroupColumnSpacing = string.Empty;
        }
    }
}
