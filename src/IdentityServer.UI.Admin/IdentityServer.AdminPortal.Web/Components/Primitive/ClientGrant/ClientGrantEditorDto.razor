@using System.Collections.Generic
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
@using IdentityServer.Abstraction.Extensions

@inherits ClientGrantEditorBase<ClientPropertyGrantDtoRead, List<ClientPropertyGrantDtoRead>>

@{
    // Display the base component markup
    base.BuildRenderTree(__builder);
}

@code {
    [Parameter]
    public Func<string, Task<(ClientPropertyGrantDtoRead?, bool)>> OnBeforeAdd { get; set; } = default!;

    [Parameter]
    public Func<ClientPropertyGrantDtoRead, Task<bool>> OnBeforeRemove { get; set; } = default!;

    [Parameter]
    public EventCallback OnAfterUpdate { get; set; }

    [Parameter]
    public bool ClientAllowsOfflineAccess { get; set; } = false;

    protected override IEnumerable<ClientGrantItemListItem> AllowedItems =>
        Value.OrderBy(g => g.GrantType)
        .Select(grantObj => new ClientGrantItemListItem
       {
            Text = GetGrantDisplayText(grantObj.GrantType),
            OnClick = EventCallback.Factory.Create(this, () => RemoveValue(grantObj)),
            IsReadonly = IsReadonly
       });

    protected override IEnumerable<ClientGrantItemListItem> AvailableItems =>
        GetAvailableGrants().Select(grant => new ClientGrantItemListItem
        {
            Text = grant.Value,
            OnClick = EventCallback.Factory.Create(this, () => AddValue(grant.Key)),
            IsReadonly = IsReadonly
        });

    protected override IEnumerable<ClientGrantItemListItem> IncompatibleItems =>
        GetIncompatibleGrants().Select(grant => new ClientGrantItemListItem
        {
            Text = grant.Value,
            Tooltip = GetGrantTooltip(grant.Key),
            IsReadonly = true
        });

    internal async Task AddValue(string value)
    {
        (var result, bool success) = await OnBeforeAdd(value);
        if (!success || result == null)
        {
            return;
        }

        Value.Add(result);
        await NotifyValueChanged();
    }

    internal async Task RemoveValue(ClientPropertyGrantDtoRead value)
    {
        if (await OnBeforeRemove(value) && Value.Remove(value))
        {
            await NotifyValueChanged();
        }
    }

    private async Task NotifyValueChanged()
    {
        await ValueChanged.InvokeAsync(Value);
        EditContext?.NotifyFieldChanged(FieldIdentifier.Create(ValueExpression));
        await OnAfterUpdate.InvokeAsync();
    }

    protected internal override bool IsAlreadyAdded(string grant)
    {
        return Value.Any(g => g.GrantType.IsSameLax(grant));
    }

    protected override bool IsGrantCompatible(string grantKey)
    {
        if (IsForbiddenImplicitGrant(grantKey))
        {
            return false;
        }

        return base.IsGrantCompatible(grantKey);
    }

    protected internal override string GetGrantTooltip(string grantKey)
    {
        var reasons = new List<string>();

        if (IsForbiddenImplicitGrant(grantKey))
        {
            reasons.Add("Implicit grant is not permitted for a client with allowed Refresh Token.");
        }

        reasons.Add(base.GetGrantTooltip(grantKey));

        return string.Join(" ", reasons);
    }

    internal bool IsForbiddenImplicitGrant(string grant)
    {
        return ClientAllowsOfflineAccess && grant.IsSameLax(ClientGrantTypeNames.Grant_Implicit);
    }
}
