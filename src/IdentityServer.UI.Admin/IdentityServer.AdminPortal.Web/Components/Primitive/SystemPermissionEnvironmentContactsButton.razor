@using Telerik.Blazor.Components
@using Telerik.DataSource
@using IdentityServer.AdminPortal.Web.Pages

@inject ISystemOwnerService SystemOwnerService
@inject IThemeService ThemeService

<div class="d-flex my-auto align-items-center">
    <TelerikButton ButtonType="ButtonType.Button" Size="sm" Icon="@ThemeService.GetInfoIcon()" ThemeColor="secondary"
                   Class="border m-0 p-0 me-1" OnClick="@(() => SystemOwnerService.ShowContactsPopup(Entity.SystemPermissionEnvironmentId))">
    </TelerikButton>
    <span id="@Id" class="text-nowrap">@Entity.SystemPermissionEnvironmentName</span>
</div>

@code{
    [Parameter]
    public IHasEnvironment Entity { get; set; } = default!;

    [Parameter]
    public string Id { get; set; } = string.Empty;
}
