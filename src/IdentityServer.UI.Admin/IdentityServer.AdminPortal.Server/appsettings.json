{
    "System": {
        "SystemName": "IdentityServer",
        "ApplicationName": "IdentityServer.AdminPortal.Server",
        "EnableLoggingDiagnosticsToConsole": false,
        "EnableLoggingDiagnosticsToFile": true,
        "LoggingDiagnosticsFile": "c:\\log\\IdentityServer_AdminPortal_SerilogDiagnostics.log",
        "Environment": "IDP DV 01",
        "EnvironmentTier": "",
        "SecurityNotice": "Security Notice",
        "SecurityDisclaimerText": "Only authorized users can login onto this system.",
        "LoadBalancer": {
            "IpRange": "10.0.0.0",
            "Mask": 8
        }
    },
    "ConnectionStrings": {
        "IDPDBConnectionString": "Server=SQLServerInstance;Database=IdentityServer;Integrated Security=true;TrustServerCertificate=True"
    },
    "Kestrel": {
        "Endpoints": {
            "IDPHttpsEndpoint": {
                "Url": "https://*:5300",
                "Certificate": {
                    "Subject": "",
                    "Store": "My",
                    "Location": "LocalMachine",
                    "AllowInvalid": false
                }
            }
        }
    },
    "Features": {
        "EnableRequestBodyLogging": false
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Async",
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File",
            "Serilog.Enrichers.Context",
            "Serilog.Enrichers.Thread",
            "Serilog.Enrichers.Process",
            "Serilog.Enrichers.Activity",
            "IdentityServer.Core.Serilog"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
            }
        },
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithActivityId" ],
        "Properties": {
            "Application": "Identity Server Admin Portal Server"
        },
        "WriteTo": [
            {
                "Name": "TradingStandardSink",
                "Args": {
                    "SinkConfig": {
                        "requestUri": "https://logstash.example.com:6201",
                        "username": "log",
                        "password": "",
                        "applicationName": "idp",
                        "bufferBaseFileName": "c:\\log\\IdentityServer_AdminPortal.Buffer",
                        "period": "0:0:0.100"
                    }
                }
            },
            {
                "Name": "Async",
                "Args": {
                    "configure": [
                        {
                            "Name": "File",
                            "Args": {
                                "path": "c:\\log\\IdentityServer_AdminPortal_Api.log",
                                "fileSizeLimitBytes": 10485760,
                                "rollOnFileSizeLimit": true,
                                "retainedFileCountLimit": 30,
                                "shared": true
                            }
                        }
                    ]
                }
            }
        ]
    },
    "MicrosoftEntra": {
        "ClientId": "00000000-0000-0000-0000-000000000001",
        "TenantId": "00000000-0000-0000-0000-000000000002",
        "ClientSecret": ""
    },
    "MicrosoftEntraCache": {
        "Enabled": true,
        "ApplicationExpiration": "00:15:00",
        "GroupExpiration": "00:15:00",
        "UserExpiration": "00:05:00"
    },
    "HttpRetryPolicy": {
        "RetryCount": 3,
        "GrowthFactorInSeconds": 1.5
    },
    "OnePassword": {
        "BaseUrl": "https://1password.company.com",
        "AccessToken": "",
        "VaultId": "Az0101zA0011z0A1",
        "Secrets": {
            "MicrosoftEntra__ClientSecret": "",
            "IdentityServer__CachingOptions__Provider__Password": ""
        }
    },
    "IdentityServerProvider": {
        "Authority": "https://identityserver.example.com:5200"
    },
    "IdentityServer": {
        "CachingOptions": {
            "Enabled": true,
            "Provider": {
                "Kind": "InMemory",
                "ConnectionString": "valkey.example.com:24732",
                "Username": "valkey_contributor",
                "Password": ""
            }
        }
    },
    "Auth": {
        "ContributorGroupId": "00000000-0000-0000-0000-000000000003",
        "ReaderGroupId": "00000000-0000-0000-0000-000000000004"
    },
    "SecretExpiration": {
        "MaxValidityYears": 3
    }
}
