{
    "ConnectionStrings": {
        "IDPDBConnectionString": "Server=.;Database=IdentityServer_local;Integrated Security=true;TrustServerCertificate=True"
    },
    "System": {
        "EnableLoggingDiagnosticsToConsole": true,
        "EnableLoggingDiagnosticsToFile": false,
        "Environment": "Local",
        "EnvironmentTier": "Local"
    },
    "Serilog": {
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}Properties:{Properties}{NewLine}{Exception}{NewLine}",
                    "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
                }
            }
        ]
    },
    "IdentityServer": {
        "CachingOptions": {
            "Enabled": false
        }
    },
    "IdentityServerProvider": {
        "Authority": "https://localhost:5200"
        //"Authority": "https://identityserverdv:5200"
    },
    "OnePassword": {
        "AccessToken": "This value must be loaded from User Secrets, please follow Developer onboarding guide or ReadMe",
        "Secrets": {
            "MicrosoftEntra__ClientSecret": "sefe-identity-server-tool-dv secret"
        }
    }
}
