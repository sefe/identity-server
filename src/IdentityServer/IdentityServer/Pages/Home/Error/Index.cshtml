@page
@model IdentityServer.Pages.Home.Error.Index

<div class="error-page">
    <div class="lead">
        <h1>Error</h1>
    </div>

    <div class="row">
        <div class="col-sm-12">
            @if (Model.View.Error == null)
            {
                <div class="alert alert-danger mb-3">
                    <p>An error occurred while processing your request. Please try again later.</p>
                </div>
                <p>No additional details are available.</p>
                @if (!string.IsNullOrWhiteSpace(Model.View.SupportEmailAddress))
                {
                    <p class="mt-3"><a href="@Model.View.GetMailLink()" class="text-50 fw-bold">Contact Support Team</a></p>
                }
            }
            else
            {
                <div class="alert alert-danger mb-3">
                    <div>
                        Error:
                        <strong>
                            <em>
                                @Model.View.Error.Error
                            </em>
                        </strong>
                    </div>
                    @if (Model.View.Error.ErrorDescription != null)
                    {
                    <div> Error Description: @Model.View.Error.ErrorDescription </div>
                    }
                </div>

                <div><b>Timestamp</b>: @Model.View.Timestamp.ToString("u")</div>
                <div class="request-id"><b>Request Id</b>: <strong>@Model.View.Error.RequestId</strong></div>
                <div><b>Activity ID</b>: @Model.View.Error.ActivityId</div>
                <div><b>ClientId</b>: @Model.View.Error.ClientId</div>
                <div><b>RedirectUri</b>: @Model.View.GetRedirectUri()</div>

                <div class="mt-3">Please refer to the <a href="https://wiki/spaces/gde/pages/582977693/MWPTI+-+IdentityServer+-+User+Guide" target="_blank" class="ms-1">documentation</a> for user and troubleshooting guides.</div>
                @if (!string.IsNullOrWhiteSpace(Model.View.SupportEmailAddress))
                {
                    <div class="mt-3">
                        <p>For further assistance please reach out to the <a href="@Model.View.GetMailLink()" class="text-50 fw-bold">support team</a>.
                            Please include the above details as well as any additional relevant information to speed up the troubleshooting.</p>
                    </div>
                }
            }
        </div>
    </div>
</div>
