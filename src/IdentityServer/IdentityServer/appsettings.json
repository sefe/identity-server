{
    "System": {
        "SystemName": "IdentityServer",
        "ApplicationName": "IdentityServer.Api",
        "EnableLoggingDiagnosticsToConsole": false,
        "EnableLoggingDiagnosticsToFile": true,
        "LoggingDiagnosticsFile": "c:\\log\\IdentityServer_Api_SerilogDiagnostics.log",
        "Environment": "IDP DV 01",
        "EnvironmentTier": "DV",
        "LoadBalancer": {
            "IpRange": "10.0.0.0",
            "Mask": 8
        },
        "SupportEmailAddress": "support@example.com"
    },
    "ConnectionStrings": {
        "IDPDBConnectionString": "Server=SQL_Instance;Database=IdentityServer;Integrated Security=true;TrustServerCertificate=True"
    },
    "Kestrel": {
        "Endpoints": {
            "IDPHttpsEndpoint": {
                "Url": "https://*:5200",
                "Certificate": {
                    "Subject": "",
                    "Store": "My",
                    "Location": "LocalMachine",
                    "AllowInvalid": false
                }
            }
        }
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Async",
            "Serilog.Sinks.Console",
            "Serilog.Sinks.File",
            "Serilog.Enrichers.Context",
            "Serilog.Enrichers.Thread",
            "Serilog.Enrichers.Process",
            "Serilog.Enrichers.Activity",
            "IdentityServer.Core.Serilog"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
            }
        },
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithActivityId" ],
        "Properties": {
            "Application": "Identity Server API"
        },
        "WriteTo": [
            {
                "Name": "TradingStandardSink",
                "Args": {
                    "SinkConfig": {
                        "requestUri": "https://logstash.example.com:6201",
                        "username": "log",
                        "password": "",
                        "applicationName": "idp",
                        "bufferBaseFileName": "c:\\log\\IdentityServer_Api.Buffer",
                        "period": "0:0:0.100"
                    }
                }
            },
            {
                "Name": "Async",
                "Args": {
                    "configure": [
                        {
                            "Name": "File",
                            "Args": {
                                "path": "c:\\log\\IdentityServer_Api.log",
                                "fileSizeLimitBytes": 10485760,
                                "rollOnFileSizeLimit": true,
                                "retainedFileCountLimit": 30,
                                "shared": true
                            }
                        }
                    ]
                }
            }
        ]
    },
    "MicrosoftEntra": {
        "ClientId": "00000000-0000-0000-0000-000000000001",
        "TenantId": "00000000-0000-0000-0000-000000000002",
        "ClientSecret": ""
    },
    "MicrosoftEntraCache": {
        "Enabled": true,
        "ApplicationExpiration": "00:15:00",
        "GroupExpiration": "00:15:00",
        "UserExpiration": "00:05:00"
    },
    "HttpRetryPolicy": {
        "RetryCount": 3,
        "GrowthFactorInSeconds": 1.5
    },
    "OnePassword": {
        "BaseUrl": "https://1password.company.com",
        "AccessToken": "",
        "VaultId": "Az0101zA0011z0A1",
        "Secrets": {
            "MicrosoftEntra__ClientSecret": "",
            "IdentityServer__CachingOptions__Provider__Password": ""
        }
    },
    "IdentityServer": {
        "CachingOptions": {
            "Enabled": true,
            "Provider": {
                "Kind": "InMemory",
                "ConnectionString": "valkey.example.com:24732",
                "Username": "valkey_contributor",
                "Password": ""
            }
        },
        "AuthenticationOptions": {
            "CookieLifetime": "10:00:00"
        }
    },
    "IdentityServerProvider": {
        "Authority": "https://identityserver.example.com:5200"
    },
    "AzureKeyVaultConnections": {
        "DataProtectionEncryptionKeyConfig": {
            "KeyVaultUrl": "https://akv.example.com/",
            "ObjectName": "identity-provider-data-protection-dv"
        },
        "IdentityServerLicenseKey": {
            "keyVaultUrl": "https://akv.example.com/",
            "ObjectName": "identity-server-license-key"
        }
    },
    "FeatureFlags": {
        "UseCustomRedirectUriValidator": true,
        "CustomTokenLoggingSettings": {
            "EnableCustomTokenLogging": true,
            "ReferenceTokenDefaultVisibleLength": 16,
            "JwtTokenVisibleParts": "Payload"
        }
    }
}
